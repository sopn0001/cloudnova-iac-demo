{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudNova Azure Naming Standards",
  "description": "Governance rules for CloudNova Terraform — used by AI-assisted review and CI/CD",
  "namingConvention": {
    "pattern": "cn-{appName}-{resourceType}",
    "examples": {
      "storageAccount": "cnsaasapistabc123",
      "virtualNetwork": "cn-saasapi-vnet",
      "networkSecurityGroup": "cn-saasapi-nsg",
      "virtualMachine": "cn-saasapi-vm",
      "appServicePlan": "cn-saasapi-asp",
      "webApp": "cn-saasapi-web"
    },
    "rules": [
      "Use lowercase for storage account names (no hyphens)",
      "Prefix all resources with cn (CloudNova)",
      "Maximum 24 characters for storage accounts"
    ]
  },
  "requiredTags": [
    "Environment",
    "Application",
    "Company",
    "ManagedBy",
    "CostCenter",
    "Owner"
  ],
  "costTiers": {
    "default": {
      "vmSize": "Standard_B2s",
      "appServicePlan": "B1",
      "storageSku": "Standard_LRS",
      "vmOsDiskGb": 64,
      "rationale": "Demo workloads use cost-efficient SKUs"
    }
  },
  "networkRules": {
    "denyInboundFromInternet": ["22", "3389"],
    "requirePrivateEndpointsForStorage": true
  }
}
